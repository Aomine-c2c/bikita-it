// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "windows"]
}
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}





model Location {
  id          String     @id @default(uuid())
  name        String
  type        String     // e.g., MINE, BUILDING, ROOM, RACK
  
  parentId    String?
  parent      Location?  @relation("LocationHierarchy", fields: [parentId], references: [id])
  children    Location[] @relation("LocationHierarchy")
  
  assets      HardwareAsset[]
  stockTransactions StockTransaction[]
}

model Employee {
  id              String            @id @default(uuid())
  name            String
  email           String            @unique
  passwordHash    String?
  department      String?
  position        String?
  office          String?
  role            String            @default("EMPLOYEE")
  
  // Relations
  hardwareAssets  HardwareAsset[]   @relation("AssignedHardware")
  repairsAssigned Repair[]          @relation("AssignedRepairs")
  stockTransactions StockTransaction[]
  connectedDevices ConnectedDevice[]
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model HardwareAsset {
  id              String           @id @default(uuid())
  tag             String           @unique // e.g. IT-0241
  name            String?
  category        String
  status          String   @default("IN_STOCK")
  make            String
  model           String
  serialNumber    String?          @unique
  
  // Specs / Network
  macAddress      String?
  ipAddress       String?
  network         String?
  computerName    String?
  operatingSystem String?
  specs           String?            // Stores CPU, RAM, OS, Storage, firmware, etc.
  
  installationDate DateTime?
  
  // Relations
  locationId      String?
  location        Location?        @relation(fields: [locationId], references: [id])
  
  assigneeId      String?
  assignee        Employee?        @relation("AssignedHardware", fields: [assigneeId], references: [id])
  repairs         Repair[]
  stockTransactions StockTransaction[]
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Database indexes for query performance
  @@index([locationId])
  @@index([assigneeId])
  @@index([status])
  @@index([createdAt])
}

model InventoryItem {
  id            String    @id @default(uuid())
  sku           String    @unique
  name          String
  category      String
  type          String?   // Consumable, Fixed Asset, Returnable Tool
  quantity      Int       @default(0)
  minStock      Int
  maxStock      Int
  binLocation   String?
  remarks       String?
  dateReceived  DateTime? @default(now())
  
  stockTransactions StockTransaction[]

  // Database indexes
  @@index([category])
  @@index([sku])
}

model Repair {
  id                  String           @id @default(uuid())
  description         String
  status              String     @default("QUEUED")
  condition           String?
  remarks             String?
  estimatedCompletion DateTime?
  
  // Relations
  hardwareId          String
  hardware            HardwareAsset    @relation(fields: [hardwareId], references: [id], onDelete: Cascade)
  
  technicianId        String?
  technician          Employee?        @relation("AssignedRepairs", fields: [technicianId], references: [id])

  // Database indexes
  @@index([hardwareId])
  @@index([technicianId])
  @@index([status])
  
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
}

model AuditLog {
  id              String           @id @default(uuid())
  action          String
  entityType      String           // e.g. HardwareAsset
  entityId        String
  details         String           // JSON stringified details
  performedById   String?          // The user who made the change
  
  createdAt       DateTime         @default(now())
}


model StockTransaction {
  id              String   @id @default(uuid())
  type            String
  quantity        Int      @default(1)
  notes           String?
  remarks         String?
  
  // What was moved?
  hardwareAssetId String?
  hardwareAsset   HardwareAsset? @relation(fields: [hardwareAssetId], references: [id], onDelete: Cascade)

  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  
  // Where did it go?
  locationId      String?  
  location        Location? @relation(fields: [locationId], references: [id])

  assigneeId      String?  
  assignee        Employee? @relation(fields: [assigneeId], references: [id])
  
  createdAt       DateTime @default(now())
}

model ConnectedDevice {
  id              String   @id @default(uuid())
  hostname        String
  macAddress      String   @unique
  ipAddress       String
  os              String?
  deviceType      String?
  connectionStatus String? @default("CONNECTED")
  accessPoint     String?
  lastSeen        DateTime @default(now())
  
  // Who owns it?
  employeeId      String?
  employee        Employee? @relation(fields: [employeeId], references: [id])
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SystemSetting {
  key       String   @id
  value     String   // Store JSON stringified values
  updatedAt DateTime @updatedAt
}

model SystemService {
  id        String   @id @default(uuid())
  name      String   @unique
  status    String   @default("online")
  uptime    String?
  latency   String?
  updatedAt DateTime @updatedAt
}
