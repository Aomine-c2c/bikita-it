// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  IT_SUPPORT
  STOREKEEPER
  PROCUREMENT
  FINANCE
  AUDITOR
  MANAGER
  EMPLOYEE
}

enum HardwareCategory {
  LAPTOP
  DESKTOP
  MONITOR
  PERIPHERAL
  NETWORKING
  SERVER
  MOBILE
  PRINTING
  POWER
  CCTV
  COMMUNICATION
}

enum HardwareStatus {
  ACTIVE
  IN_REPAIR
  RETIRED
  IN_STOCK
  ASSIGNED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RepairStatus {
  QUEUED
  WAITING_PARTS
  IN_PROGRESS
  COMPLETED
}

model Location {
  id          String     @id @default(uuid())
  name        String
  type        String     // e.g., MINE, BUILDING, ROOM, RACK
  
  parentId    String?
  parent      Location?  @relation("LocationHierarchy", fields: [parentId], references: [id])
  children    Location[] @relation("LocationHierarchy")
  
  assets      HardwareAsset[]
}

model Employee {
  id              String            @id @default(uuid())
  name            String
  email           String            @unique
  department      String?
  role            Role              @default(EMPLOYEE)
  
  // Relations
  hardwareAssets  HardwareAsset[]   @relation("AssignedHardware")
  softwareSeats   SoftwareSeat[]    @relation("AssignedSeats")
  authoredTickets SupportTicket[]   @relation("AuthoredTickets")
  assignedTickets SupportTicket[]   @relation("AssignedTickets")
  repairsAssigned Repair[]          @relation("AssignedRepairs")
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model HardwareAsset {
  id              String           @id @default(uuid())
  tag             String           @unique // e.g. IT-0241
  category        HardwareCategory
  status          HardwareStatus   @default(IN_STOCK)
  make            String
  model           String
  serialNumber    String?          @unique
  purchaseCost    Float?
  purchaseDate    DateTime?
  warrantyExpiry  DateTime?
  
  // Expanded Specs (Digital Twin)
  macAddress      String?
  ipAddress       String?
  specs           Json?            // Stores CPU, RAM, OS, Storage, firmware, etc.
  
  // Relations
  locationId      String?
  location        Location?        @relation(fields: [locationId], references: [id])
  
  assigneeId      String?
  assignee        Employee?        @relation("AssignedHardware", fields: [assigneeId], references: [id])
  repairs         Repair[]
  tickets         SupportTicket[]
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model InventoryItem {
  id            String    @id @default(uuid())
  sku           String    @unique
  name          String
  category      String
  quantity      Int       @default(0)
  minStock      Int
  maxStock      Int
  binLocation   String?
  costPerUnit   Float
  supplier      String?
}

model SoftwareLicense {
  id              String           @id @default(uuid())
  name            String
  vendor          String
  version         String?
  totalSeats      Int
  costPerSeat     Float?
  renewalDate     DateTime?
  
  // Relations
  assignedSeats   SoftwareSeat[]
  tickets         SupportTicket[]
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model SoftwareSeat {
  id              String           @id @default(uuid())
  
  // Relations
  licenseId       String
  license         SoftwareLicense  @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  
  assigneeId      String
  assignee        Employee         @relation("AssignedSeats", fields: [assigneeId], references: [id], onDelete: Cascade)
  
  assignedAt      DateTime         @default(now())
  
  @@unique([licenseId, assigneeId])
}

model SupportTicket {
  id              String           @id @default(uuid())
  title           String
  description     String
  status          TicketStatus     @default(OPEN)
  priority        TicketPriority   @default(MEDIUM)
  
  // Relations
  authorId        String
  author          Employee         @relation("AuthoredTickets", fields: [authorId], references: [id])
  
  assigneeId      String?
  assignee        Employee?        @relation("AssignedTickets", fields: [assigneeId], references: [id])
  
  hardwareId      String?
  hardware        HardwareAsset?   @relation(fields: [hardwareId], references: [id])
  
  softwareId      String?
  software        SoftwareLicense? @relation(fields: [softwareId], references: [id])
  
  repairs         Repair[]
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Repair {
  id                  String           @id @default(uuid())
  description         String
  cost                Float?
  status              RepairStatus     @default(QUEUED)
  estimatedCompletion DateTime?
  
  // Relations
  hardwareId          String
  hardware            HardwareAsset    @relation(fields: [hardwareId], references: [id], onDelete: Cascade)
  
  technicianId        String?
  technician          Employee?        @relation("AssignedRepairs", fields: [technicianId], references: [id])
  
  ticketId            String?
  ticket              SupportTicket?   @relation(fields: [ticketId], references: [id])
  
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
}

model AuditLog {
  id              String           @id @default(uuid())
  action          String
  entityType      String           // e.g. HardwareAsset, SoftwareLicense
  entityId        String
  details         String           // JSON stringified details
  performedById   String?          // The user who made the change
  
  createdAt       DateTime         @default(now())
}
