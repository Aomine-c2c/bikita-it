# ──────────────────────────────────────
# Xiphos IT Operations Platform — Environment
# ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# For production: docker compose up -d
# For dev (WSL):  ./start-wsl.sh

# Database
POSTGRES_USER=xiphos
POSTGRES_PASSWORD=change-this-to-a-strong-password
POSTGRES_DB=xiphos

# This is used by the API container to connect to Postgres (Docker internal DNS)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# For local dev without Docker, use localhost instead of "postgres":
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# Backend
PORT=3001
ALLOWED_ORIGINS=http://localhost:3000

# Frontend → Backend proxy (used by Next.js rewrites)
API_INTERNAL_URL=http://127.0.0.1:3001
NEXT_PUBLIC_API_URL=/api

# ──────────────────────────────────────
# Option A — Docker Compose (Production)
# ──────────────────────────────────────
#   cp .env.example .env
#   # Edit .env with your secrets
#   docker compose up -d
#   # Visit http://localhost:3000

# ──────────────────────────────────────
# Option B — Local dev (no Docker)
# ──────────────────────────────────────
#   1. Make sure Postgres is running locally
#   2. Create the database
#   3. Set DATABASE_URL to localhost in .env
#   4. cd apps/api && npx prisma migrate deploy && npx prisma db seed
#   5. cd apps/api && npm run start:dev
#   6. cd apps/web && npm run dev
